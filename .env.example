NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase PostgreSQL + Prisma
# DATABASE_URL: 앱 실행용 Pooler URL. Supabase Dashboard > Project Settings > Database > Connection string > Transaction pooler
DATABASE_URL="postgresql://postgres.xxxxx:비밀번호@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# DIRECT_URL: Prisma migrate용 Direct URL. Supabase Dashboard > Project Settings > Database > Connection string > Direct connection
DIRECT_URL="postgresql://postgres:비밀번호@db.xxxxx.supabase.co:5432/postgres"

# Vercel Cron 보호용. 운영 환경에서는 반드시 설정
CRON_SECRET="원하는긴문자열"

# 관리자 API 보호용. 운영 배포 전 인증 기능과 함께 설정
ADMIN_SECRET="별도의긴관리자문자열"
